# BLT API environment sample
# Copy to .env (local) and set real values.
# Do NOT commit real secrets.

# Shared defaults
BLT_API_BASE_URL=https://api.owaspblt.org/v2
BLT_WEBSITE_URL=https://owaspblt.org
JWT_SECRET=your_jwt_secret_here
USER_DATA_ENCRYPTION_KEY=your_user_data_encryption_key_here
USER_DATA_HASH_KEY=your_user_data_hash_key_here
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=sandbox123...mailgun.org

# Production example overrides
PRODUCTION_BLT_API_BASE_URL=https://api.owaspblt.org/v2
PRODUCTION_BLT_WEBSITE_URL=https://owaspblt.org
PRODUCTION_JWT_SECRET=your_jwt_secret_here
PRODUCTION_USER_DATA_ENCRYPTION_KEY=your_user_data_encryption_key_here
PRODUCTION_USER_DATA_HASH_KEY=your_user_data_hash_key_here
PRODUCTION_MAILGUN_API_KEY=your_mailgun_api_key_here
PRODUCTION_MAILGUN_DOMAIN=yourdomain.com

# Development example overrides
DEVELOPMENT_BLT_API_BASE_URL=http://localhost:8787/v2
DEVELOPMENT_BLT_WEBSITE_URL=http://localhost:8000
DEVELOPMENT_JWT_SECRET=your_dev_jwt_secret_here
DEVELOPMENT_USER_DATA_ENCRYPTION_KEY=your_dev_user_data_encryption_key_here
DEVELOPMENT_USER_DATA_HASH_KEY=your_dev_user_data_hash_key_here
DEVELOPMENT_MAILGUN_API_KEY=your_dev_mailgun_api_key_here
DEVELOPMENT_MAILGUN_DOMAIN=sandbox123...mailgun.org
